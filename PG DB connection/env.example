DB_USER=your_username
DB_HOST=localhost
DB_NAME=your_database_name
DB_PASSWORD=your_password
DB_PORT=5432

# alternatively, if you are using a connection string (like Supabase), use:
# DATABASE_URL=postgres://your_username:your_password@localhost:5432/your_database_name

youll have to add this database url to the environment variable when you deplot
